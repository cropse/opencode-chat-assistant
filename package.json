{
  "name": "@ih-chung/opencode-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram and Discord bot client for OpenCode to run and monitor coding tasks from chat.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "opencode-telegram": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config.example.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "dev:watch": "tsx watch src/index.ts",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:rc": "node scripts/release-prepare.mjs rc",
    "release:notes:preview": "node scripts/release-notes-preview.mjs",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IH-Chung/opencode-telegram-bot.git"
  },
  "keywords": [
    "opencode",
    "telegram",
    "telegram-bot",
    "grammy",
    "discord",
    "discord-bot",
    "developer-tools",
    "cli"
  ],
  "author": "IH-Chung",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/IH-Chung/opencode-telegram-bot/issues"
  },
  "homepage": "https://github.com/IH-Chung/opencode-telegram-bot#readme",
  "dependencies": {
    "@opencode-ai/sdk": "^1.1.21",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
